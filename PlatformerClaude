import pygame

# Colors
WHITE = (255, 255, 255)
BLACK = (0, 0, 0)
GREEN = (100, 200, 100)
BROWN = (139, 90, 43)
BLUE = (135, 206, 235)
RED = (200, 50, 50)

# Player settings
PLAYER_WIDTH = 32
PLAYER_HEIGHT = 48
GRAVITY = 0.8
JUMP_STRENGTH = -15
MOVE_SPEED = 7


class Player:
    def __init__(self, x, y, frames=None, fps=8):
        self.rect = pygame.Rect(x, y, 30, 50)

        self.vel_x = 0
        self.vel_y = 0
        self.on_ground = False
        self.health = 100

        # Animation
        self.frames = frames if frames else []
        self.fps = fps
        self.frame_index = 0
        self.frame_timer = 0
        self.facing_right = True

        # ✅ FIX: prevents jump/idle flicker
        self.air_timer = 0

    def handle_input(self, keys):
        self.vel_x = 0

        if keys[pygame.K_LEFT] or keys[pygame.K_a]:
            self.vel_x = -MOVE_SPEED
            self.facing_right = False

        if keys[pygame.K_RIGHT] or keys[pygame.K_d]:
            self.vel_x = MOVE_SPEED
            self.facing_right = True

        if (keys[pygame.K_SPACE] or keys[pygame.K_w] or keys[pygame.K_UP]) and self.on_ground:
            self.vel_y = JUMP_STRENGTH
            self.on_ground = False

    def apply_gravity(self):
        self.vel_y += GRAVITY
        if self.vel_y > 15:
            self.vel_y = 15

    def move_and_collide(self, platforms):
        # Horizontal
        self.rect.x += self.vel_x
        for platform in platforms:
            if self.rect.colliderect(platform):
                if self.vel_x > 0:
                    self.rect.right = platform.left
                elif self.vel_x < 0:
                    self.rect.left = platform.right

        # Vertical
        self.rect.y += self.vel_y
        self.on_ground = False

        for platform in platforms:
            if self.rect.colliderect(platform):
                if self.vel_y > 0:
                    self.rect.bottom = platform.top
                    self.vel_y = 0
                    self.on_ground = True
                elif self.vel_y < 0:
                    self.rect.top = platform.bottom
                    self.vel_y = 0

        # ✅ FIX: stabilize ground/air state
        if self.on_ground:
            self.air_timer = 0
        else:
            self.air_timer += 1

    def update_animation(self, dt):
        if not self.frames:
            return

        # 🟦 JUMP (stable check using buffer)
        if self.air_timer > 1:
            self.frame_index = 3
            self.frame_timer = 0
            return

        moving = self.vel_x != 0

        # 🟨 IDLE
        if not moving:
            self.frame_index = 2
            self.frame_timer = 0
            return

        # 🟩 RUN
        self.frame_timer += dt
        if self.frame_timer >= 1 / self.fps:
            self.frame_timer = 0
            self.frame_index += 1
            if self.frame_index > 1:
                self.frame_index = 0

    def draw(self, screen):
        if self.frames:
            frame = self.frames[self.frame_index]

            if not self.facing_right:
                frame = pygame.transform.flip(frame, True, False)

            draw_x = self.rect.x + (self.rect.width - frame.get_width()) // 2
            draw_y = self.rect.y + (self.rect.height - frame.get_height())

            screen.blit(frame, (draw_x, draw_y))
        else:
            pygame.draw.rect(screen, GREEN, self.rect)


class Enemy:
    def __init__(self, x, y, patrol_range=100):
        self.rect = pygame.Rect(x, y, 30, 30)
        self.start_x = x
        self.patrol_range = patrol_range
        self.direction = 1
        self.speed = 2

    def update(self):
        self.rect.x += self.speed * self.direction

        if self.rect.x > self.start_x + self.patrol_range:
            self.direction = -1
        elif self.rect.x < self.start_x:
            self.direction = 1

    def draw(self, screen):
        pygame.draw.rect(screen, RED, self.rect)


def platformer_loop(screen, clock):
    SCREEN_WIDTH = screen.get_width()
    SCREEN_HEIGHT = screen.get_height()

    SCALE = 4
    frames = [
        pygame.transform.scale(pygame.image.load("AlienSkin1.png").convert_alpha(), (13*SCALE, 17*SCALE)),
        pygame.transform.scale(pygame.image.load("AlienSkin2.png").convert_alpha(), (13*SCALE, 17*SCALE)),
        pygame.transform.scale(pygame.image.load("AlienSkin3.png").convert_alpha(), (13*SCALE, 17*SCALE)),
        pygame.transform.scale(pygame.image.load("AlienSkinJump.png").convert_alpha(), (13*SCALE, 17*SCALE)),
    ]

    player = Player(100, 400, frames)

    platforms = [
        pygame.Rect(0, 550, 800, 50),
        pygame.Rect(200, 450, 150, 20),
        pygame.Rect(450, 380, 150, 20),
        pygame.Rect(150, 300, 150, 20),
        pygame.Rect(500, 220, 150, 20),
        pygame.Rect(50, 200, 80, 20),
    ]

    enemies = [
        Enemy(225, 420, 100),
        Enemy(465, 350, 80),
    ]

    combat_zone = pygame.Rect(700, 500, 50, 50)
    font = pygame.font.Font(None, 24)

    while True:
        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                return "menu"
            if event.type == pygame.KEYDOWN:
                if event.key == pygame.K_ESCAPE:
                    return "menu"
                if event.key == pygame.K_c:
                    return "combat"

        keys = pygame.key.get_pressed()
        player.handle_input(keys)

        player.apply_gravity()
        player.move_and_collide(platforms)

        for enemy in enemies:
            enemy.update()
            if player.rect.colliderect(enemy.rect):
                return "combat"

        if player.rect.colliderect(combat_zone):
            return "combat"

        if player.rect.left < 0:
            player.rect.left = 0
        if player.rect.right > SCREEN_WIDTH:
            player.rect.right = SCREEN_WIDTH
        if player.rect.top > SCREEN_HEIGHT:
            player.rect.x = 100
            player.rect.y = 400
            player.vel_y = 0

        dt = clock.tick(60) / 1000
        player.update_animation(dt)

        screen.fill(BLUE)

        for platform in platforms:
            pygame.draw.rect(screen, BROWN, platform)

        pygame.draw.rect(screen, (200, 200, 50), combat_zone)
        screen.blit(font.render("COMBAT", True, BLACK), (combat_zone.x - 5, combat_zone.y - 20))

        for enemy in enemies:
            enemy.draw(screen)

        player.draw(screen)

        screen.blit(font.render("WASD/Arrows: Move | SPACE: Jump | ESC: Menu | C: Combat", True, BLACK), (10, 10))
        screen.blit(font.render(f"Health: {player.health}", True, BLACK), (10, 35))

        pygame.display.flip()
