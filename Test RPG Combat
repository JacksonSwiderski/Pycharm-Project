def combat_loop(screen, clock):
    battle = Battle()

    while True:
        events = pygame.event.get()

        for event in events:
            if event.type == pygame.QUIT:
                return "menu"
            if event.type == pygame.KEYDOWN:
                if event.key == pygame.K_ESCAPE:
                    return "menu"

        battle.update(events)
        battle.draw(screen)

        pygame.display.flip()
        clock.tick(60)
