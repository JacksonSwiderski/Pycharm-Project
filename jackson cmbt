        if self.state == BattleState.PLAYER_TURN:
            move = self.menu.update(events)
            if move:
                self.message = apply_move(self.player, self.enemy, move)
                self.state = BattleState.RESULT
                self.turn_locked = True


        elif self.state == BattleState.RESULT:
            for e in events:
                if e.type == pygame.KEYDOWN and e.key == pygame.K_z:
                    if self.enemy.hp <= 0:
                        self.message = 'Enemy defeated!'
                        self.state = BattleState.OUTCOME
                    elif self.player.hp <= 0:
                        self.message = 'You were defeated...'
                        self.state = BattleState.OUTCOME
                    else:
                        if self.turn_locked:
                            self.state = BattleState.ENEMY_ATTACK
                            self.message = ''
                        elif not self.turn_locked:
                            self.state = BattleState.PLAYER_TURN
                            self.message = ''


        elif self.state == BattleState.ENEMY_ATTACK:
            if self.turn_locked:
                move = random.choice(self.enemy.moves)
                self.message = apply_move(self.enemy, self.player, move)
                self.turn_locked = False
            for e in events:
                if e.type == pygame.KEYDOWN and e.key == pygame.K_z:
                    self.state = BattleState.RESULT
                    self.turn_locked = False

        elif self.state == BattleState.OUTCOME:
            for e in events:
                if e.type == pygame.KEYDOWN and e.key == pygame.K_z:
                    return 'platformer'
