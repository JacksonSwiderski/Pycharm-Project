                (255, 255, 0),
                (player.rect.x - camera_x, player.rect.y, player.rect.width, player.rect.height),
                2
            )

            # ENEMIES (screen space)
            for e in enemies:
                pygame.draw.rect(
                    screen,
                    (0, 255, 0),
                    (e.rect.x - camera_x, e.rect.y, e.rect.width, e.rect.height),
                    2
                )

            # PLATFORMS (screen space)
            for p in platforms:
                pygame.draw.rect(
                    screen,
                    (0, 0, 255),
                    (p.x - camera_x, p.y, p.width, p.height),
                    2
                )

        # 🔥 LIVE MOUSE PIXELS (FIXED)
        mx, my = pygame.mouse.get_pos()

        coords_text = ui_font.render(f"{mx}, {my}", True, WHITE)
        screen.blit(coords_text, (10, SCREEN_HEIGHT - 25))

        pygame.draw.line(screen, WHITE, (mx - 10, my), (mx + 10, my), 1)
        pygame.draw.line(screen, WHITE, (mx, my - 10), (mx, my + 10), 1)

        for pos in clicked_points:
            x, y = pos

            # draw dot
            pygame.draw.circle(screen, WHITE, (x, y), 3)

            # draw text above
            coords_text = ui_font.render(f"{x}, {y}", True, WHITE)
            screen.blit(coords_text, (x - 20, y - 20))

        pygame.display.flip()
