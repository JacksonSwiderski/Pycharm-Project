        if dev_mode:
            camera_x = 0
        else:
            camera_x = player.rect.x - SCREEN_WIDTH // 2
            camera_x = max(0, camera_x)
            camera_x = min(camera_x, 2000 - SCREEN_WIDTH)

        # DRAW
        # screen.fill(BLUE)
        screen.blit(bg_img, (0, 0))

        for rect in background_rects:
            # Create a surface exactly the size of the rect
            surf = pygame.Surface((rect.width, rect.height), pygame.SRCALPHA)

            # Tile inside this surface (starts at 0,0 now)
            for x in range(0, rect.width, tile_w):
                for y in range(0, rect.height, tile_h):
                    draw_w = min(tile_w, rect.width - x)
                    draw_h = min(tile_h, rect.height - y)

                    tile = bg_tile_img.subsurface((0, 0, draw_w, draw_h))
                    surf.blit(tile, (x, y))

            # 🔵 OPTIONAL: Rounded edges (crop corners)
            radius = 6
            mask = pygame.Surface((rect.width, rect.height), pygame.SRCALPHA)
            pygame.draw.rect(mask, (255, 255, 255),
                             (0, 0, rect.width, rect.height),
                             border_radius=radius)

            surf.blit(mask, (0, 0), special_flags=pygame.BLEND_RGBA_MULT)

            # Draw final result to screen
            screen.blit(surf, (rect.x - camera_x, rect.y))

        for p in platforms:
            shifted = pygame.Rect(p.x - camera_x, p.y, p.width, p.height)
            draw_platform(screen, grass_img, shifted)

        for s in spawnpoints:
            screen.blit(spawn_img, (s.x - camera_x, s.y))

        for e in enemies:
            e.draw(screen, camera_x)

        player.draw(screen, camera_x)

        # CONTROLS
        if show_controls:
            controls = [
                "WASD / Arrows: Move",
                "SPACE: Jump",
                "F3 + B or `: Toggle Hitboxes",
                "H: Toggle Controls",
                "ESC: Menu"
            ]

            for i, line in enumerate(controls):
                txt = ui_font.render(line, True, WHITE)
                screen.blit(txt, (10, 10 + i * 18))

        # HITBOXES
        if show_hitboxes:

            # PLAYER (screen space)
            pygame.draw.rect(
