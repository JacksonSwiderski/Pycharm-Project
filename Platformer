class Player:
    def __init__(self, x, y, chosenCharacter=None, fps=10):
        self.rect = pygame.Rect(x, y, 22, 30)

        self.vel_x = 0
        self.vel_y = 0
        self.on_ground = False
        self.health = 100

        self.chosenCharacter = chosenCharacter if chosenCharacter else []
        self.fps = fps
        self.frame_index = 0
        self.frame_timer = 0
        self.facing_right = True

        self.air_timer = 0

    def handle_input(self, keys):
        self.vel_x = 0

        if keys[pygame.K_LEFT] or keys[pygame.K_a]:
            self.vel_x = -MOVE_SPEED
            self.facing_right = False

        if keys[pygame.K_RIGHT] or keys[pygame.K_d]:
            self.vel_x = MOVE_SPEED
            self.facing_right = True

        if (keys[pygame.K_SPACE] or keys[pygame.K_w] or keys[pygame.K_UP]) and self.on_ground:
            self.vel_y = JUMP_STRENGTH
            self.on_ground = False

    def apply_gravity(self):
        self.vel_y += GRAVITY
        if self.vel_y > 15:
            self.vel_y = 15

    def move_and_collide(self, platforms):
        self.rect.x += self.vel_x
        for p in platforms:
            if self.rect.colliderect(p):
                if self.vel_x > 0:
                    self.rect.right = p.left
                elif self.vel_x < 0:
                    self.rect.left = p.right

        self.rect.y += self.vel_y
        self.on_ground = False

        for p in platforms:
            if self.rect.colliderect(p):
                if self.vel_y > 0:
                    self.rect.bottom = p.top
                    self.vel_y = 0
                    self.on_ground = True
                elif self.vel_y < 0:
                    self.rect.top = p.bottom
                    self.vel_y = 0

        self.air_timer = 0 if self.on_ground else self.air_timer + 1

    def update_animation(self, dt):
        if not self.chosenCharacter:
            return

        # AIR (jumping)
        if self.air_timer > 1:
            self.frame_index = 3
            self.frame_timer = 0
            return

        # IDLE
        if self.vel_x == 0:
            self.frame_index = 2
            self.frame_timer = 0
            return

        # WALKING
        self.frame_timer += dt

        if self.frame_timer >= 0.1:  # 👈 fixed speed (0.1 = fast, 0.2 = slower)
            self.frame_timer = 0
            self.frame_index += 1

            # loop between frames 0 and 1
            if self.frame_index > 1:
                self.frame_index = 0

    def draw(self, screen, camera_x):
        if self.chosenCharacter:
            frame = self.chosenCharacter[self.frame_index]

            if not self.facing_right:
                frame = pygame.transform.flip(frame, True, False)

            draw_x = self.rect.x - camera_x + (self.rect.width - frame.get_width()) // 2
            draw_y = self.rect.bottom - frame.get_height()

            screen.blit(frame, (draw_x, draw_y))
        else:
            pygame.draw.rect(screen, GREEN, self.rect)

def world_to_screen(rect, camera_x):
    return pygame.Rect(rect.x - camera_x, rect.y, rect.width, rect.height)

class Enemy:
    def __init__(self, x, y, patrol_range=100, frames=None):
        self.rect = pygame.Rect(x, y, 22, 30)
        self.start_x = x
        self.range = patrol_range
        self.dir = 1
        self.speed = 1

        self.frames = frames if frames else []
        self.frame_index = 0
        self.frame_timer = 0

    def update(self, dt):
        # movement
        self.rect.x += self.speed * self.dir

        if self.rect.x > self.start_x + self.range:
            self.dir = -1
        elif self.rect.x < self.start_x:
            self.dir = 1

        # animation
        if self.frames:
            self.frame_timer += dt

            if self.frame_timer >= 0.25:  # speed of float animation
                self.frame_timer = 0
                self.frame_index += 1

                if self.frame_index >= len(self.frames):
                    self.frame_index = 0

    def draw(self, screen, camera_x):
        draw_x = self.rect.x - camera_x

        if self.frames:
            frame = self.frames[self.frame_index]

            # flip if moving left
            if self.dir < 0:
                frame = pygame.transform.flip(frame, True, False)

            screen.blit(frame, (draw_x, self.rect.y))
        else:
            pygame.draw.rect(screen, RED, (draw_x, self.rect.y, self.rect.width, self.rect.height))


