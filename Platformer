import pygame

# Colors
WHITE = (255, 255, 255)
BLACK = (0, 0, 0)
GREEN = (100, 200, 100)
BROWN = (139, 90, 43)
BLUE = (135, 206, 235)
RED = (200, 50, 50)

# Settings
GRAVITY = 0.8
JUMP_STRENGTH = -10
MOVE_SPEED = 5
DIRT_COLOR = (66, 44, 31)  # #422C1F

mousePixelToggle = True # to find pixels/ does not work rn

# ground tiles
grass_img = pygame.image.load("GrasslandGround.jpg").convert()
grass_img = pygame.transform.scale(grass_img, (32, 32))  # adjust if needed
def draw_platform(screen, image, rect):
    tile_w = image.get_width()
    tile_h = image.get_height()

    # Create a transparent surface the size of the platform
    platform_surf = pygame.Surface((rect.width, rect.height), pygame.SRCALPHA)

    # --- TOP: tile grass ---
    for x in range(0, rect.width, tile_w):
        draw_w = min(tile_w, rect.width - x)
        tile = image.subsurface((0, 0, draw_w, tile_h))
        platform_surf.blit(tile, (x, 0))

    # --- BELOW: dirt fill ---
    if rect.height > tile_h:
        dirt_rect = pygame.Rect(0, tile_h, rect.width, rect.height - tile_h)
        pygame.draw.rect(platform_surf, DIRT_COLOR, dirt_rect)

    # --- CREATE ROUNDED MASK ---
    radius = 5  # adjust for more/less roundness

    mask = pygame.Surface((rect.width, rect.height), pygame.SRCALPHA)
    pygame.draw.rect(mask, (255, 255, 255), (0, 0, rect.width, rect.height), border_radius=radius)

    # Apply mask (this cuts corners)
    platform_surf.blit(mask, (0, 0), special_flags=pygame.BLEND_RGBA_MULT)

    # Draw final result
    screen.blit(platform_surf, (rect.x, rect.y))




