import pygame
import sys
from test_plat import platformer_loop
from test_cmbt import combat_loop

# Initialize Pygame
pygame.init()
pygame.mixer.init()

# Screen settings
SCREEN_WIDTH = 800
SCREEN_HEIGHT = 600
screen = pygame.display.set_mode((SCREEN_WIDTH, SCREEN_HEIGHT))
pygame.display.set_caption("Chrono Clash")

# Colors
WHITE = (255, 255, 255)
BLACK = (0, 0, 0)
GREEN = (100, 200, 100)
BLUE = (100, 100, 200)
GRAY = (50, 50, 50)

# Fonts
font = pygame.font.Font(None, 48)
small_font = pygame.font.Font(None, 32)

# Logo (NEW)
logo = pygame.image.load("ChronoClashLogo.png").convert_alpha()
logo = pygame.transform.scale(logo, (500, 300))

# Game states
STATE_MENU = "menu"
STATE_LEVEL_SELECT = "level_select"
STATE_PLATFORMER = "platformer"
STATE_COMBAT = "combat"

show_hitboxes = False
current_enemy = None
defeated_enemies = []
current_state = STATE_MENU

player_x = 100
player_y = 400

clock = pygame.time.Clock()

def draw_button(text, x, y, width, height, color, hover_color):
    mouse = pygame.mouse.get_pos()
    click = pygame.mouse.get_pressed()

    rect = pygame.Rect(x, y, width, height)
    is_hovered = rect.collidepoint(mouse)

    pygame.draw.rect(screen, hover_color if is_hovered else color, rect, border_radius=8)
    pygame.draw.rect(screen, WHITE, rect, 2, border_radius=8)

    text_surface = small_font.render(text, True, WHITE)
    text_rect = text_surface.get_rect(center=rect.center)
    screen.blit(text_surface, text_rect)

    return is_hovered and click[0]


# UPDATED TITLE FUNCTION (LOGO INSTEAD OF TEXT)
def createTitle():
    screen.blit(
        logo,
        (SCREEN_WIDTH // 2 - logo.get_width() // 2, 15)
    )


def main_menu():
    global current_state

    screen.fill(GRAY)

    # Logo title
    createTitle()

    # Buttons
    if draw_button("Play", 300, 250, 200, 50, GREEN, (120, 220, 120)):
        pygame.time.delay(150)
        current_state = STATE_LEVEL_SELECT

    if draw_button("Testing", 300, 320, 200, 50, (65, 65, 65), (88, 88, 88)):
        pygame.time.delay(150)
        current_state = STATE_PLATFORMER

    if draw_button("Quit", 300, 390, 200, 50, (150, 50, 50), (180, 80, 80)):
        pygame.quit()
        sys.exit()


def level_select():
    global current_state

    screen.fill(GRAY)

    title = font.render("SELECT LEVEL", True, WHITE)
    screen.blit(title, (SCREEN_WIDTH // 2 - title.get_width() // 2, 50))

    levels = ["Grassy Plains", "Desert", "Mountains", "Jungle", "Volcanic"]

    for i, level_name in enumerate(levels):
        row = i // 3
        col = i % 3
        x = 100 + col * 220
        y = 150 + row * 100

        if draw_button(level_name, x, y, 180, 60, GREEN, (120, 220, 120)):
            pygame.time.delay(150)
            current_state = STATE_PLATFORMER

    if draw_button("Back", 20, 550, 100, 40, (100, 100, 100), (130, 130, 130)):
        pygame.time.delay(150)
        current_state = STATE_MENU


def run_platformer():
    global current_enemy, current_state
    global player_x, player_y
    global defeated_enemies

    result, show_hitboxes, enemy_data, player_x, player_y = platformer_loop(
        screen,
        clock,
        False,
        player_x,
        player_y,
        defeated_enemies
    )

    if result == "menu":
        current_state = STATE_MENU
        return

    if result == "combat":
        current_enemy = enemy_data
        current_state = STATE_COMBAT

def run_combat():
    global current_state, current_enemy, defeated_enemy

    result = combat_loop(screen, clock, current_enemy)

    if result == "menu":
        current_state = STATE_MENU
    elif result == "platformer":
        current_state = STATE_PLATFORMER
    elif result == 'enemy_defeated':
        defeated_enemies.append(current_enemy.enemy_id)
        print(defeated_enemies)
        current_state = STATE_PLATFORMER


def main():
    global current_state

    running = True
    while running:
        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                running = False

        if current_state == STATE_MENU:
            main_menu()
        elif current_state == STATE_LEVEL_SELECT:
            level_select()
        elif current_state == STATE_PLATFORMER:
            run_platformer()
        elif current_state == STATE_COMBAT:
            run_combat()

        pygame.display.flip()
        clock.tick(60)

    pygame.quit()
    sys.exit()


if __name__ == "__main__":
    main()
