    if draw_button("Testing", 300, 320, 200, 50, (65, 65, 65), (88, 88, 88)):
        pygame.time.delay(150)
        current_state = STATE_PLATFORMER

    if draw_button("Quit", 300, 390, 200, 50, (150, 50, 50), (180, 80, 80)):
        pygame.quit()
        sys.exit()

